rules_version = '2';

// Portal.C Firebase Storage セキュリティルール
// アバター画像の保存用。Admin SDK経由でアップロード、署名付きURLで読み取り。

service firebase.storage {
  match /b/{bucket}/o {

    // avatarsディレクトリ: Admin SDK経由のみ書き込み、読み取りは認証ユーザー
    match /avatars/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    // その他のパスは全て拒否
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
